# Sendy MySQL database (for Analytics / Reports real data).
# Leave unset to use mock data on the dashboard.
SENDY_DB_HOST=localhost
SENDY_DB_USER=sendy_user
SENDY_DB_PASSWORD=your_password
SENDY_DB_NAME=sendy

# Optional: table prefix if your Sendy DB uses one (e.g. "sendy_" => tables sendy_campaigns, sendy_subscribers, sendy_links).
# SENDY_DB_TABLE_PREFIX=

# Optional: campaigns recipient count column (Sendy may use "recipients" or "to_send").
# SENDY_DB_RECIPIENT_COLUMN=to_send

# Expected Sendy tables (no prefix):
# - campaigns: id, app (brand_id), title or subject, sent (datetime), to_send or recipients (count), opens (text, comma-separated id:country), optional: bounces, unsubscribes
# - subscribers: id, list, email, optional: country
# - links: campaign_id, optional: clicks (per-link click count; else total rows = click events)
